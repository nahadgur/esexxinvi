# Lead pipeline destination — Slack webhook, Make.com, Zapier, or your own HTTPS endpoint
LEAD_WEBHOOK_URL=

# GA4 Measurement Protocol — server-side conversion relay
# Find values in GA4 Admin > Data Streams > [your stream] > Measurement Protocol API secrets
GA4_MEASUREMENT_ID=
GA4_API_SECRET=

# Bundle analyzer toggle (set to "true" then run `npm run analyze`)
ANALYZE=false
